<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>배송 상태 관리 - Refresh Beverage Mall</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Apple SD Gothic Neo", "Noto Sans KR", system-ui, sans-serif; -webkit-font-smoothing: antialiased; margin: 0; padding: 40px; background-color: #f8fafc; color: #1e293b; }
        .admin-container { max-width: 1100px; margin: 0 auto; background: white; padding: 40px; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05); }
        .board-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; border-bottom: 2px solid #0f172a; padding-bottom: 20px; }
        h2 { font-size: 24px; font-weight: 800; color: #0f172a; margin: 0; }
        .btn-home { color: #64748b; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 6px; }
        .btn-home:hover { color: #0f172a; text-decoration: underline; }

        .management-table { width: 100%; border-collapse: collapse; font-size: 14px; margin-bottom: 20px; }
        .management-table th { background-color: #f1f5f9; color: #475569; font-weight: 700; padding: 16px 12px; border-bottom: 2px solid #e2e8f0; text-align: center; }
        .management-table td { padding: 16px 12px; border-bottom: 1px solid #e2e8f0; text-align: center; vertical-align: middle; color: #334155; }
        .management-table tr:hover { background-color: #f8fafc; }
        .prod-id { font-family: monospace; color: #94a3b8; font-weight: 600; }

        /* 🚩 원버튼 상태 제어 태그 스타일 정의 */
        .btn-status-toggle {
            color: white; border: none; padding: 10px 18px; border-radius: 8px;
            font-weight: bold; cursor: pointer; font-size: 13px; transition: all 0.2s;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        }
        .btn-status-toggle:hover { transform: translateY(-1px); opacity: 0.9; }

        /* 상태별 버튼 색상 테마 배정 */
        .status-ready { background-color: #0ea5e9; box-shadow: 0 4px 12px rgba(14, 165, 233, 0.2); } /* 결제완료 상태일 때 */
        .status-shipping { background-color: #f59e0b; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2); } /* 배송중 상태일 때 */

        footer { margin-top: 50px; text-align: center; font-size: 13px; color: #94a3b8; }
    </style>
</head>
<body>
<div class="admin-container">
    <header class="board-header">
        <h2>🚚 고객 주문 및 배송 상태 일괄 처리장</h2>
        <a href="./" class="btn-home">⬅ 대시보드로 복귀</a>
    </header>

    <main>
        <table class="management-table">
            <thead>
            <tr>
                <th style="width: 12%;">주문번호</th>
                <th style="width: 23%;">고객 정보</th>
                <th style="width: 15%;">총 결제액</th>
                <th style="width: 20%;">주문 접수일</th>
                <th style="width: 30%;">배송 상태 제어</th>
            </tr>
            </thead>
            <tbody>
            <% if (typeof orders !== 'undefined' && orders && orders.length > 0) { %>
                <% orders.forEach(order => { %>
                    <tr>
                        <td class="prod-id">#<%= order.orderId %></td>
                        <td style="font-weight: 700;"><%= order.userName %> <span style="font-size:12px; color:#64748b;">(<%= order.status %>)</span></td>
                        <td style="font-weight: 600; color: #0ea5e9;">₩<%= order.totalPrice.toLocaleString() %></td>
                        <td style="font-size: 13px; color: #64748b;"><%= order.createdAt.substring(0, 16) %></td>
                        <td>
                            <form action="orders/update-status" method="POST" style="margin: 0; padding: 0;">
                                <input type="hidden" name="orderId" value="<%= order.orderId %>">
                                <input type="hidden" name="currentStatus" value="<%= order.status %>">

                                <% if (order.status === '결제완료') { %>
                                    <button type="submit" class="btn-status-toggle status-ready">
                                        📦 결제완료 ➔ [배송 시작]
                                    </button>
                                <% } else if (order.status === '배송중') { %>
                                    <button type="submit" class="btn-status-toggle status-shipping">
                                        🚚 배송중 ➔ [배송 완료]
                                    </button>
                                <% } else { %>
                                    <button type="button" class="btn-status-toggle" style="background-color:#94a3b8;" disabled>
                                        <%= order.status %>
                                    </button>
                                <% } %>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="5" style="padding: 50px; color: #94a3b8; font-weight: 500;">현재 처리해야 할 활성 주문이 없습니다. 🧊</td></tr>
            <% } %>
            </tbody>
        </table>
    </main>
    <footer>&copy; 2026 시스템 관리 센터. All rights reserved.</footer>
</div>
</body>
</html>