<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>고객센터 게시판</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Malgun Gothic", "맑은 고딕", helvetica, sans-serif;
            background-color: #f8fafc;
            margin: 0;
            padding: 50px 20px;
            color: #333333;
            display: flex;
            justify-content: center;
        }

        .board-container {
            width: 100%;
            max-width: 1100px;
            background: #ffffff;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
            border: 1px solid #e2e8f0;
            box-sizing: border-box;
        }

        .board-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 20px;
            margin-bottom: 30px;
            border-bottom: 2px solid #f1f5f9;
        }

        h2 {
            font-size: 24px;
            font-weight: bold;
            color: #0f172a;
            margin: 0;
        }

        .header-nav {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .header-nav a.btn-back {
            color: #64748b;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
        }
        .header-nav a.btn-back:hover {
            color: #0f172a;
        }

        .btn-write-box {
            display: inline-block;
            background-color: #3b82f6;
            color: #ffffff !important;
            padding: 10px 18px;
            font-size: 14px;
            font-weight: bold;
            text-decoration: none;
            border-radius: 8px;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
            transition: all 0.2s;
        }
        .btn-write-box:hover {
            background-color: #2563eb;
            transform: translateY(-1px);
        }

        .board-table {
            width: 100%;
            border-collapse: collapse;
            border-top: 3px solid #0f172a;
            font-size: 14px;
        }

        .board-table th {
            background-color: #f8fafc;
            color: #475569;
            font-weight: 700;
            padding: 16px 10px;
            border-bottom: 1px solid #e2e8f0;
            text-align: center;
        }

        .board-table td {
            padding: 16px 10px;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
            vertical-align: middle;
        }

        .board-table tr:hover {
            background-color: #f8fafc;
        }

        /* 공지사항 행 배경 구분 색상 */
        .notice-row {
            background-color: #f1f5f9;
        }
        .notice-badge {
            background-color: #ef4444;
            color: white;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
        }

        .col-id { text-align: center; color: #94a3b8; font-family: monospace; font-size: 15px; }
        .col-title { text-align: left; padding-left: 20px; }
        .col-author { text-align: center; color: #475569; font-weight: 600; }
        .col-date { text-align: center; color: #94a3b8; }

        .post-link {
            color: #1e293b;
            text-decoration: none;
            font-weight: 600;
        }
        .post-link:hover {
            color: #3b82f6;
            text-decoration: underline;
        }

        .reply-tag {
            color: #64748b;
            font-weight: bold;
            margin-right: 6px;
        }

        .action-links {
            font-size: 12px;
            margin-left: 12px;
            display: inline-block;
        }
        .action-links a {
            color: #cbd5e1;
            text-decoration: none;
            margin: 0 2px;
        }
        .action-links a:hover {
            color: #ef4444;
            text-decoration: underline;
        }

        footer {
            margin-top: 50px;
            text-align: center;
            font-size: 13px;
            color: #94a3b8;
            border-top: 1px solid #f1f5f9;
            padding-top: 20px;
        }
    </style>
</head>
<body>

<div class="board-container">
    <header class="board-header">
        <h2>고객센터 게시판</h2>
        <nav class="header-nav">
            <a href="../" class="btn-back">홈으로</a>
            <a href="board/new" class="btn-write-box">문의글 쓰기</a>
        </nav>
    </header>

    <main>
        <table class="board-table">
            <thead>
            <tr>
                <th style="width: 12%;">번호</th>
                <th style="width: 53%;">제목</th>
                <th style="width: 15%;">작성자</th>
                <th style="width: 20%;">작성일</th>
            </tr>
            </thead>
            <tbody>
            <% if (posts && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <tr class="<%= post.is_notice === 1 ? 'notice-row' : '' %>">
                        <td class="col-id">
                            <% if (post.is_notice === 1) { %>
                                <span class="notice-badge">공지</span>
                            <% } else { %>
                                #<%= post.id %>
                            <% } %>
                        </td>

                        <td class="col-title" style="padding-left: <%= post.parent_id ? '40px' : '20px' %>;">
                            <a href="board/view/<%= post.id %>" class="post-link">
                                <% if (post.parent_id) { %>
                                    <span class="reply-tag">↳ [답변]</span>
                                <% } %>
                                <%= post.title %>
                            </a>

                            <span class="action-links">
                                (<a href="board/edit/<%= post.id %>">수정</a> /
                                 <a href="board/delete/<%= post.id %>">삭제</a>)
                            </span>
                        </td>

                        <td class="col-author"><%= post.author %></td>
                        <td class="col-date">
                            <%= post.created_at ? post.created_at.substring(11, 16) : '08:18' %>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="4" style="padding: 50px; text-align: center; color: #94a3b8;">등록된 게시글이 없습니다.</td></tr>
            <% } %>
            </tbody>
        </table>
    </main>

    <footer>
        &copy; 2026 Refresh Beverage Mall. All rights reserved.
    </footer>
</div>

</body>
</html>